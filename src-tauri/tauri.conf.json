{
  "productName": "DevReel",
  "version": "0.1.0",
  "identifier": "com.sooraj.devreel",
  "build": {
  "frontendDist": "../src/dist",
  "devUrl": "http://localhost:1420",
  "beforeDevCommand": "cd src && yarn dev",
  "beforeBuildCommand": "cd src && yarn build"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "DevReel Studio",
        "width": 1280,
        "height": 820,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {}
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "infoPlist": null
    }
  }
}